<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Tic Tac Toe</title><style>body{text-align:center;background:#111;color:#fff;}table{margin:auto;}td{width:100px;height:100px;border:3px solid #0f0;font-size:60px;cursor:pointer;}</style></head><body><h1>❌⭕ Tic Tac Toe</h1><table><tr><td onclick="play(this)"></td><td onclick="play(this)"></td><td onclick="play(this)"></td></tr><tr><td onclick="play(this)"></td><td onclick="play(this)"></td><td onclick="play(this)"></td></tr><tr><td onclick="play(this)"></td><td onclick="play(this)"></td><td onclick="play(this)"></td></tr></table><button onclick="reset()">Reset</button><script>let current='X';function play(cell){if(cell.textContent) return; cell.textContent=current; current=current==='X'?'O':'X';}function reset(){document.querySelectorAll('td').forEach(td=>td.textContent='');current='X';}</script></body></html>
